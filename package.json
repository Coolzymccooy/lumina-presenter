{
  "name": "lumina-presenter",
  "private": true,
  "version": "2.4.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "server": "node scripts/server-start.mjs",
    "start": "node scripts/server-start.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:dev:raw": "electron .",
    "dist:win": "npm run build && electron-rebuild -f -w better-sqlite3 && electron-builder --win --publish never",
    "dist:win:ci": "npm run build && electron-rebuild -f -w better-sqlite3 && electron-builder --win --publish never --config.directories.output=release",
    "dist:win:publish": "npm run build && electron-rebuild -f -w better-sqlite3 && electron-builder --win --publish always",
    "dist:mac": "npm run build && electron-rebuild -f -w better-sqlite3 && electron-builder --mac --universal --publish never",
    "dist:mac:ci": "npm run build && electron-rebuild -f -w better-sqlite3 && electron-builder --mac --universal --publish never --config.directories.output=release",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:smoke": "node scripts/run-e2e.mjs --grep @smoke",
    "test:e2e:headed": "node scripts/run-e2e.mjs --headed",
    "test:e2e:ui": "node scripts/run-e2e.mjs --ui",
    "test:e2e:install": "playwright install chromium",
    "postinstall": "electron-rebuild -f -w @stagetimerio/grandiose",
    "hymn:normalize": "node scripts/normalizePdHymn.mjs data/hymns/pd/",
    "hymn:build": "node scripts/buildPdBundle.mjs",
    "hymn:check": "node scripts/buildPdBundle.mjs --check",
    "hymn:import": "node scripts/importFromHymnal.mjs",
    "bible:bundle": "node scripts/buildBibleBundle.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "@stagetimerio/grandiose": "^0.1.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "multer": "^2.1.1",
    "pdf-to-png-converter": "^3.11.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-player": "^3.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.4.1"
  },
  "build": {
    "appId": "com.luminapresenter.app",
    "productName": "Lumina Presenter",
    "npmRebuild": true,
    "asar": true,
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "C:\\lumina-build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.d",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@stagetimerio/grandiose/dist/**",
      "node_modules/better-sqlite3/**",
      "server/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.png",
      "artifactName": "Lumina-Presenter-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "notarize": false,
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Lumina-Presenter-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Lumina-Presenter-${version}.exe"
    },
    "msi": {
      "artifactName": "Lumina-Presenter-${version}.msi"
    },
    "dmg": {
      "artifactName": "Lumina-Presenter-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Coolzymccooy",
      "repo": "lumina-presenter",
      "releaseType": "release"
    },
    "copyright": "Copyright (c) 2026 Lumina Presenter"
  },
  "description": "Lumina Presenter: Native presentation software for churches.",
  "main": "electron/main.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
